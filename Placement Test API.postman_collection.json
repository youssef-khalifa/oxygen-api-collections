        {
          "name": "Create Placement Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"en\",\n  \"levelRanges\": [\n    {\n      \"minScore\": 0,\n      \"maxScore\": 49,\n      \"level\": \"A1\",\n      \"courses\": [\"{{course_id_1}}\",\"{{course_id_2}}\"]\n    },\n    {\n      \"minScore\": 50,\n      \"maxScore\": 100,\n      \"level\": \"B1\",\n      \"courses\": [\"{{course_id_2}}\"]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/placement-tests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "placement-tests"
              ]
            },
            "description": "Admin: Create a new placement test for a language with score ranges and suggested courses. Practice bank is created automatically."
          },
          "response": []
        },

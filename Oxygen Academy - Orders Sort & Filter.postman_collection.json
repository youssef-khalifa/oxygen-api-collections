              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response structure is valid\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.orders).to.be.an('array');",
                  "    pm.expect(jsonData.data.pagination).to.be.an('object');",
                  "});",
                  "",
                  "pm.test(\"Default sorting is by createdAt descending\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.orders.length > 1) {",
                  "        var first = new Date(jsonData.data.orders[0].createdAt);",
                  "        var second = new Date(jsonData.data.orders[1].createdAt);",
                  "        pm.expect(first.getTime()).to.be.at.least(second.getTime());",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
